@page
@model CRCardSwipe.Pages.Staff.ViewTimesheetModel
@{
    ViewData["Title"] = "My Timesheet";
}

<div class="row">
    <div class="col-12">
        <h1><i class="fas fa-calendar-alt icon-primary"></i> MY TIMESHEET</h1>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header">
        <h5><i class="fas fa-filter"></i> Date Range</h5>
    </div>
    <div class="card-body">
        <form method="get">
            <div class="row align-items-end">
                <div class="col-md-4">
                    <div class="mb-3 mb-md-0">
                        <label asp-for="StartDate" class="form-label">Start Date</label>
                        <input asp-for="StartDate" type="date" class="form-control" />
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="mb-3 mb-md-0">
                        <label asp-for="EndDate" class="form-label">End Date</label>
                        <input asp-for="EndDate" type="date" class="form-control" />
                    </div>
                </div>
                <div class="col-md-4">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-search"></i> Update
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5><i class="fas fa-clock"></i> Time Entries for @Model.DisplayName</h5>
        <span class="badge bg-primary fs-6">Total: @Math.Floor(Model.TotalHours)h @((int)((Model.TotalHours % 1) * 60))m</span>
    </div>
    <div class="card-body">
        @if (Model.Entries.Any())
        {
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <caption class="visually-hidden">Timesheet entries</caption>
                    <thead class="table-dark">
                        <tr>
                            <th scope="col">Date</th>
                            <th scope="col">Check-In</th>
                            <th scope="col">Check-Out</th>
                            <th scope="col">Duration</th>
                            <th scope="col">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var entry in Model.Entries)
                        {
                            <tr class="@(entry.IsCheckedIn ? "table-info" : "")">
                                <td>@entry.CheckinTimestamp.ToString("MM/dd/yyyy")</td>
                                <td>@entry.CheckinTimestamp.ToString("h:mm tt")</td>
                                <td>@(entry.CheckoutTimestamp?.ToString("h:mm tt") ?? "-")</td>
                                <td>@entry.DurationDisplay</td>
                                <td>
                                    @if (entry.IsCheckedIn)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else if (entry.HoursWorked > 12)
                                    {
                                        <span class="badge bg-warning text-dark">Long Shift</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Complete</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="alert alert-info">
                <i class="fas fa-info-circle"></i> No timesheet entries found for the selected date range.
            </div>
        }
    </div>
</div>
