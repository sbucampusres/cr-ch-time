@page
@model CRCardSwipe.Pages.CardSwipe.ViewVisitsModel
@{
    ViewData["Title"] = "View Visits";
}

<div class="row">
    <div class="col-12">
        <h1><i class="fas fa-history icon-primary"></i> VIEW VISITS</h1>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header">
        <h5><i class="fas fa-filter"></i> Filter Visits</h5>
    </div>
    <div class="card-body">
        <form method="get">
            <div class="row">
                <div class="col-md-3">
                    <div class="mb-3">
                        <label asp-for="StartDate" class="form-label">Start Date</label>
                        <input asp-for="StartDate" type="date" class="form-control" />
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="mb-3">
                        <label asp-for="EndDate" class="form-label">End Date</label>
                        <input asp-for="EndDate" type="date" class="form-control" />
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="mb-3">
                        <label asp-for="SBUID" class="form-label">SBUID</label>
                        <input asp-for="SBUID" class="form-control" placeholder="9-digit SBUID" maxlength="9" />
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="mb-3">
                        <label asp-for="BuildingId" class="form-label">Building</label>
                        <select asp-for="BuildingId" class="form-select"
                                asp-items="@(new SelectList(Model.Buildings, "BuildingId", "Name"))">
                            <option value="">All Buildings</option>
                        </select>
                    </div>
                </div>
            </div>
            <button type="submit" class="btn btn-primary">
                <i class="fas fa-search"></i> Search
            </button>
            <a asp-page="ViewVisits" class="btn btn-outline-secondary">
                <i class="fas fa-undo"></i> Reset
            </a>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5><i class="fas fa-list"></i> Visit Results</h5>
        <div class="d-flex align-items-center gap-2">
            <span class="badge bg-primary">@Model.TotalVisits visits</span>
            <span class="badge bg-secondary">@Model.UniqueVisitors unique visitors</span>
            @if (Model.Visits.Any())
            {
                <a asp-page-handler="Export"
                   asp-route-startDate="@Model.StartDate.ToString("yyyy-MM-dd")"
                   asp-route-endDate="@Model.EndDate.ToString("yyyy-MM-dd")"
                   asp-route-sbuid="@Model.SBUID"
                   asp-route-buildingId="@Model.BuildingId"
                   class="btn btn-outline-secondary btn-sm">
                    <i class="fas fa-download"></i> Export CSV
                </a>
            }
        </div>
    </div>
    <div class="card-body">
        @if (Model.Visits.Any())
        {
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <caption class="visually-hidden">Visit records</caption>
                    <thead class="table-dark">
                        <tr>
                            <th scope="col">Date/Time</th>
                            <th scope="col">SBUID</th>
                            <th scope="col">Name</th>
                            <th scope="col">Location</th>
                            <th scope="col">Note</th>
                            <th scope="col">Recorded By</th>
                            <th scope="col">Computer</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var visit in Model.Visits)
                        {
                            <tr>
                                <td>@visit.SwipeTime.ToString("MM/dd/yyyy h:mm tt")</td>
                                <td><code>@visit.SBUID</code></td>
                                <td>@visit.FullName</td>
                                <td>@(visit.Location ?? "-")</td>
                                <td>@(visit.Note ?? "-")</td>
                                <td>@(visit.NetIdAudit ?? "-")</td>
                                <td><small class="text-muted">@(visit.Hostname ?? "-")</small></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="alert alert-info">
                <i class="fas fa-info-circle"></i> No visits found for the selected criteria.
            </div>
        }
    </div>
</div>
