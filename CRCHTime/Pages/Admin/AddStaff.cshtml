@page
@model CRCHTime.Pages.Admin.AddStaffModel
@{
    ViewData["Title"] = "Add Staff Member";
}

<div class="row">
	<div class="col-12">
		<h1><i class="fas fa-user-plus icon-primary"></i> ADD STAFF MEMBER</h1>
		<p class="text-muted">Application: <strong>@Model.CurrentApplication</strong></p>
	</div>
</div>

@if (!string.IsNullOrEmpty(Model.StatusMessage))
{
	<div class="alert @(Model.IsSuccess ? "alert-success" : "alert-danger") alert-dismissible fade show"
		role="@(Model.IsSuccess ? "status" : "alert")"
		aria-live="@(Model.IsSuccess ? "polite" : "assertive")">
		<i class="fas @(Model.IsSuccess ? "fa-check-circle" : "fa-exclamation-circle")"></i>
		@Model.StatusMessage
		<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
	</div>
}

<div class="row justify-content-center">
	<div class="col-lg-6">
		<div class="card">
			<div class="card-header">
				<h5 class="mb-0"><i class="fas fa-user-plus"></i> New Staff Member</h5>
			</div>
			<div class="card-body">
				<form method="post">
					<fieldset>
						<legend class="visually-hidden">Staff member details</legend>

						<div class="mb-3">
							<label for="NetId" class="form-label">NetID <span class="text-danger" aria-hidden="true">*</span></label>
							<div class="input-group">
								<input asp-for="NetId" id="NetId" class="form-control" placeholder="e.g. jsmith"
									  autocomplete="off" autocapitalize="none" />
								<button type="button" class="btn btn-outline-secondary" id="lookupBtn"
										 aria-label="Look up NetID in directory">
									<i class="fas fa-search"></i> Lookup
								</button>
							</div>
							<div id="lookupResult" class="form-text" aria-live="polite"></div>
						</div>

						<div class="mb-3">
							<label for="Role" class="form-label">Role</label>
							<select asp-for="Role" id="Role" class="form-select">
								<option value="">-- Select Role --</option>
								<option value="chadmin">Administrator</option>
								<option value="chsupervisor">Supervisor</option>
								<option value="chuser">Staff</option>
							</select>
						</div>

						<div class="mb-3">
							<label for="DeptId" class="form-label">Location</label>
							<select asp-for="DeptId" id="DeptId" class="form-select">
								<option value="">-- Select Location --</option>
								@foreach (var dept in Model.Departments)
								{
									<option value="@dept.DeptId">@dept.Name</option>
								}
							</select>
						</div>

						<div class="mb-4">
							<label for="TerminationDate" class="form-label">Termination Date</label>
							<input asp-for="TerminationDate" id="TerminationDate" type="date" class="form-control" />
							<div class="form-text">Leave blank for staff with no planned end date.</div>
						</div>

						<div class="d-flex gap-2">
							<button type="submit" class="btn btn-primary">
								<i class="fas fa-save"></i> Add Staff Member
							</button>
							<a asp-page="ManageStaff" class="btn btn-outline-secondary">Cancel</a>
						</div>
					</fieldset>
				</form>
			</div>
		</div>
	</div>
</div>

@section Scripts {
	<script>
		document.getElementById('lookupBtn').addEventListener('click', async function () {
			const netId = document.getElementById('NetId').value.trim();
			const resultEl = document.getElementById('lookupResult');

			if (!netId) {
				resultEl.textContent = 'Please enter a NetID first.';
				resultEl.className = 'form-text text-warning';
				return;
			}

			this.disabled = true;
			resultEl.textContent = 'Looking up...';
			resultEl.className = 'form-text text-muted';

			try {
				const resp = await fetch(`?handler=LookupNetId&netId=${encodeURIComponent(netId)}`);
				const data = await resp.json();

				if (data.error) {
					resultEl.textContent = data.error;
					resultEl.className = 'form-text text-danger';
				} else {
					resultEl.textContent = `Found: ${data.name || '(no name)'} — ${data.email || '(no email)'}`;
					resultEl.className = 'form-text text-success';
				}
			} catch {
				resultEl.textContent = 'Lookup failed. Please try again.';
				resultEl.className = 'form-text text-danger';
			} finally {
				this.disabled = false;
			}
		});

		// Also trigger lookup on Enter in the NetID field
		document.getElementById('NetId').addEventListener('keydown', function (e) {
			if (e.key === 'Enter') {
				e.preventDefault();
				document.getElementById('lookupBtn').click();
			}
		});
	</script>
}
