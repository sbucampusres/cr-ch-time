@page
@model CRCHTime.Pages.Admin.ManageDepartmentsModel
@{
    ViewData["Title"] = "Departments";
}

<div class="row align-items-center mb-3">
    <div class="col">
        <h1><i class="fas fa-sitemap icon-primary"></i> DEPARTMENTS</h1>
        <p class="text-muted">Application: <strong>@Model.CurrentApplication</strong></p>
    </div>
    <div class="col-auto">
        <a asp-page="/Admin/AddDepartment" class="btn btn-primary">
            <i class="fas fa-plus"></i> Add Department
        </a>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.StatusMessage))
{
    <div class="alert @(Model.IsSuccess ? "alert-success" : "alert-danger") alert-dismissible fade show"
         role="@(Model.IsSuccess ? "status" : "alert")" aria-live="polite">
        <i class="fas @(Model.IsSuccess ? "fa-check-circle" : "fa-exclamation-circle")"></i>
        @Model.StatusMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (Model.Departments.Any())
{
    <div class="card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <caption class="visually-hidden">Departments for @Model.CurrentApplication</caption>
                    <thead>
                        <tr>
                            <th scope="col">Name</th>
                            <th scope="col">Status</th>
                            <th scope="col">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var dept in Model.Departments)
                        {
                            <tr>
                                <td><strong>@dept.Name</strong></td>
                                <td>
                                    @if (dept.Inactive)
                                    {
                                        <span class="badge bg-secondary">Inactive</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                </td>
                                <td>
                                    <a asp-page="/Admin/EditDepartment"
                                       asp-route-id="@dept.DeptId"
                                       class="btn btn-sm btn-outline-primary me-1">
                                        <i class="fas fa-edit"></i> Edit
                                    </a>
                                    @if (!dept.Inactive)
                                    {
                                        <form method="post" asp-page-handler="Deactivate" asp-route-id="@dept.DeptId"
                                              class="d-inline"
                                              onsubmit="return confirm('Deactivate department \'@dept.Name\'? Staff assigned to this department will not be affected.');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-warning">
                                                <i class="fas fa-ban"></i> Deactivate
                                            </button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
else
{
    <div class="alert alert-info">
        <i class="fas fa-info-circle"></i> No departments defined yet.
        <a asp-page="/Admin/AddDepartment" class="alert-link">Add the first one.</a>
    </div>
}
