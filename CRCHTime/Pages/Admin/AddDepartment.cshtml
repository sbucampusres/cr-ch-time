@page
@model CRCHTime.Pages.Admin.AddDepartmentModel
@{
    ViewData["Title"] = "Add Department";
}

<div class="row">
    <div class="col-12">
        <h1><i class="fas fa-plus icon-primary"></i> ADD DEPARTMENT</h1>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-body">
                <form method="post">
                    <fieldset>
                        <legend class="visually-hidden">New Department</legend>

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <div class="mb-4">
                            <label asp-for="Department.Name" class="form-label">Department Name <span aria-hidden="true" class="text-danger">*</span></label>
                            <input asp-for="Department.Name" class="form-control" required autofocus
                                   maxlength="40" aria-required="true" />
                            <span asp-validation-for="Department.Name" class="text-danger small"></span>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save"></i> Save Department
                            </button>
                            <a asp-page="/Admin/ManageDepartments" class="btn btn-outline-secondary">
                                Cancel
                            </a>
                        </div>
                    </fieldset>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
