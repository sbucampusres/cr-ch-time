@page
@model CRCHTime.Pages.Admin.ManageAllotmentsModel
@{
    ViewData["Title"] = $"Manage Allotments — {Model.Year}";
}

<div class="row">
    <div class="col-12">
        <h1><i class="fas fa-sliders-h icon-primary"></i> MANAGE ALLOTMENTS</h1>
        <p class="text-muted">Application: <strong>@Model.CurrentApplication</strong></p>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.StatusMessage))
{
    <div class="alert @(Model.IsSuccess ? "alert-success" : "alert-danger") alert-dismissible fade show"
         role="@(Model.IsSuccess ? "status" : "alert")"
         aria-live="@(Model.IsSuccess ? "polite" : "assertive")">
        <i class="fas @(Model.IsSuccess ? "fa-check-circle" : "fa-exclamation-circle")"></i>
        @Model.StatusMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card mb-3">
    <div class="card-body py-2">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-auto">
                <label for="yearInput" class="form-label mb-0">Year</label>
                <input id="yearInput" type="number" name="Year" value="@Model.Year"
                       min="2020" max="2099" class="form-control" style="width: 100px" />
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-outline-primary">
                    <i class="fas fa-arrow-right"></i> Load
                </button>
            </div>
            <div class="col-auto ms-auto d-flex align-items-end">
                <a asp-page="AllotmentsReport" asp-route-Year="@Model.Year" class="btn btn-outline-secondary">
                    <i class="fas fa-chart-bar"></i> View Report
                </a>
            </div>
        </form>
    </div>
</div>

@if (!Model.Departments.Any() || !Model.Categories.Any())
{
    <div class="alert alert-warning">
        <i class="fas fa-exclamation-triangle"></i>
        @if (!Model.Departments.Any())
        {
            <span>No active departments found. </span>
        }
        @if (!Model.Categories.Any())
        {
            <span>No active shift categories found.</span>
        }
    </div>
}
else
{
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0"><i class="fas fa-table"></i> Hourly Allotments — @Model.Year</h5>
            <small class="text-muted">Enter hours per department / shift category combination. Leave blank for no allotment.</small>
        </div>
        <div class="card-body p-0">
            <form method="post">
                <input type="hidden" asp-for="Year" />
                <div class="table-responsive">
                    <table class="table table-bordered table-sm mb-0 align-middle">
                        <caption class="visually-hidden">Annual hour allotments for @Model.Year — rows are departments, columns are shift categories</caption>
                        <thead class="table-light">
                            <tr>
                                <th scope="col" class="ps-3">Department</th>
                                @foreach (var cat in Model.Categories)
                                {
                                    <th scope="col" class="text-center">@cat.Name</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @{int idx = 0;}
                            @foreach (var dept in Model.Departments)
                            {
                                <tr>
                                    <th scope="row" class="ps-3 fw-normal">@dept.Name</th>
                                    @foreach (var cat in Model.Categories)
                                    {
                                        var existing = Model.GetExistingHours(dept.DeptId, cat.Id);
                                        <td class="text-center p-1">
                                            <input type="hidden" name="Cells[@idx].DeptId"     value="@dept.DeptId" />
                                            <input type="hidden" name="Cells[@idx].CategoryId" value="@cat.Id" />
                                            <input type="number"
                                                   name="Cells[@idx].Hours"
                                                   value="@(existing?.ToString("0.##") ?? "")"
                                                   min="0" step="0.5"
                                                   class="form-control form-control-sm text-center"
                                                   style="min-width: 75px"
                                                   aria-label="@dept.Name — @cat.Name hours allotment"
                                                   placeholder="—" />
                                        </td>
                                        idx++;
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="p-3 border-top d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save"></i> Save Allotments
                    </button>
                    <a asp-page="AllotmentsReport" asp-route-Year="@Model.Year" class="btn btn-outline-secondary">
                        <i class="fas fa-chart-bar"></i> View Report
                    </a>
                </div>
            </form>
        </div>
    </div>
}
