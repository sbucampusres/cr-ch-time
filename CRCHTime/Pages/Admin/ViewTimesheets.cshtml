@page
@model CRCHTime.Pages.Admin.ViewTimesheetsModel
@{
    ViewData["Title"] = "All Timesheets";
}

<div class="row">
    <div class="col-12">
        <h1><i class="fas fa-calendar-alt icon-primary"></i> ALL TIMESHEETS</h1>
        <p class="text-muted">Application: <strong>@Model.CurrentApplication</strong></p>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.StatusMessage))
{
    <div class="alert @(Model.IsSuccess ? "alert-success" : "alert-danger") alert-dismissible fade show"
         role="@(Model.IsSuccess ? "status" : "alert")" aria-live="polite">
        <i class="fas @(Model.IsSuccess ? "fa-check-circle" : "fa-exclamation-circle")"></i>
        @Model.StatusMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card mb-4">
    <div class="card-header">
        <h5 class="mb-0"><i class="fas fa-filter"></i> Filters</h5>
    </div>
    <div class="card-body">
        <form method="get">
            <div class="row g-3 align-items-end">
                <div class="col-md-2">
                    <label asp-for="StartDate" class="form-label">Start Date</label>
                    <input asp-for="StartDate" type="date" class="form-control" />
                </div>
                <div class="col-md-2">
                    <label asp-for="EndDate" class="form-label">End Date</label>
                    <input asp-for="EndDate" type="date" class="form-control" />
                </div>
                <div class="col-md-2">
                    <label asp-for="FilterNetId" class="form-label">NetID</label>
                    <input asp-for="FilterNetId" class="form-control" placeholder="Filter by NetID" autocomplete="off" />
                </div>
                @if (Model.Departments.Any())
                {
                    <div class="col-md-2">
                        <label asp-for="FilterDepartmentId" class="form-label">Location</label>
                        <select asp-for="FilterDepartmentId" class="form-select"
                                asp-items="@(new SelectList(Model.Departments, "DeptId", "Name"))">
                            <option value="">All Locations</option>
                        </select>
                    </div>
                }
                @if (Model.ShiftCategories.Any())
                {
                    <div class="col-md-2">
                        <label asp-for="FilterCategoryId" class="form-label">Category</label>
                        <select asp-for="FilterCategoryId" class="form-select"
                                asp-items="@(new SelectList(Model.ShiftCategories, "Id", "Name"))">
                            <option value="">All Categories</option>
                        </select>
                    </div>
                }
                <div class="col-md-auto">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-search"></i> Search
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

@if (Model.Entries.Any())
{
    <div class="row mb-3 g-2">
        <div class="col-auto">
            <div class="card text-bg-primary">
                <div class="card-body py-2 px-3">
                    <div class="small">Total Hours</div>
                    <div class="fw-bold fs-5">@Math.Floor(Model.GrandTotalHours)h @((int)((Model.GrandTotalHours % 1) * 60))m</div>
                </div>
            </div>
        </div>
        <div class="col-auto">
            <div class="card text-bg-secondary">
                <div class="card-body py-2 px-3">
                    <div class="small">Entries</div>
                    <div class="fw-bold fs-5">@Model.Entries.Count</div>
                </div>
            </div>
        </div>
        <div class="col-auto">
            <div class="card text-bg-info">
                <div class="card-body py-2 px-3">
                    <div class="small">Staff</div>
                    <div class="fw-bold fs-5">@Model.Summary.Count</div>
                </div>
            </div>
        </div>
        <div class="col-auto ms-auto d-flex align-items-end gap-2">
            <a asp-page-handler="Export"
               asp-route-startDate="@Model.StartDate.ToString("yyyy-MM-dd")"
               asp-route-endDate="@Model.EndDate.ToString("yyyy-MM-dd")"
               asp-route-filterNetId="@Model.FilterNetId"
               asp-route-filterLocationId="@Model.FilterDepartmentId"
               asp-route-filterCategoryId="@Model.FilterCategoryId"
               class="btn btn-outline-secondary">
                <i class="fas fa-download"></i> Export CSV
            </a>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header">
            <h5 class="mb-0"><i class="fas fa-tags"></i> Hours by Shift Category</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-sm mb-0">
                    <caption class="visually-hidden">Total hours per shift category</caption>
                    <thead>
                        <tr>
                            <th scope="col">Category</th>
                            <th scope="col">Shifts</th>
                            <th scope="col">Total Hours</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in Model.CategorySummary)
                        {
                            <tr>
                                <td>@c.Category</td>
                                <td>@c.EntryCount</td>
                                <td>@Math.Floor(c.TotalHours)h @((int)((c.TotalHours % 1) * 60))m</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-group-divider">
                        <tr class="fw-bold">
                            <td>Total</td>
                            <td>@Model.Entries.Count</td>
                            <td>@Math.Floor(Model.GrandTotalHours)h @((int)((Model.GrandTotalHours % 1) * 60))m</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>

    @if (Model.Summary.Count > 1)
    {
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0"><i class="fas fa-chart-bar"></i> Summary by Staff Member</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-sm mb-0">
                        <caption class="visually-hidden">Hours summary per staff member</caption>
                        <thead>
                            <tr>
                                <th scope="col">NetID</th>
                                <th scope="col">Entries</th>
                                <th scope="col">Total Hours</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var s in Model.Summary)
                            {
                                <tr>
                                    <td><code>@s.NetId</code></td>
                                    <td>@s.EntryCount</td>
                                    <td>@Math.Floor(s.TotalHours)h @((int)((s.TotalHours % 1) * 60))m</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-group-divider">
                            <tr class="fw-bold">
                                <td>Total</td>
                                <td>@Model.Entries.Count</td>
                                <td>@Math.Floor(Model.GrandTotalHours)h @((int)((Model.GrandTotalHours % 1) * 60))m</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    }

    <div class="card">
        <div class="card-header">
            <h5 class="mb-0"><i class="fas fa-list"></i> Time Entries</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <caption class="visually-hidden">All timesheet entries for @Model.CurrentApplication</caption>
                    <thead>
                        <tr>
                            <th scope="col">NetID</th>
                            <th scope="col">Date</th>
                            <th scope="col">Check-In</th>
                            <th scope="col">In Computer</th>
                            <th scope="col">Check-Out</th>
                            <th scope="col">Out Computer</th>
                            <th scope="col">Duration</th>
                            <th scope="col">Location</th>
                            <th scope="col">Category</th>
                            <th scope="col">Status</th>
                            <th scope="col"><span class="visually-hidden">Actions</span></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var entry in Model.Entries)
                        {
                            <tr class="@(entry.IsCheckedIn ? "table-info" : "")">
                                <td><code>@entry.NetId</code></td>
                                <td>@entry.CheckinTimestamp.ToString("MM/dd/yyyy")</td>
                                <td>@entry.CheckinTimestamp.ToString("h:mm tt")</td>
                                <td><small class="text-muted">@(entry.CheckinHostname ?? "—")</small></td>
                                <td>@(entry.CheckoutTimestamp?.ToString("h:mm tt") ?? "—")</td>
                                <td><small class="text-muted">@(entry.CheckoutHostname ?? "—")</small></td>
                                <td>@entry.DurationDisplay</td>
                                <td>@(entry.DepartmentName ?? "—")</td>
                                <td>@(entry.ShiftCategoryName ?? "—")</td>
                                <td>
                                    @if (entry.IsCheckedIn)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else if (entry.HoursWorked > 12)
                                    {
                                        <span class="badge bg-warning text-dark">Long Shift</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Complete</span>
                                    }
                                </td>
                                <td>
                                    <button type="button"
                                            class="btn btn-sm btn-outline-secondary edit-entry-btn"
                                            data-bs-toggle="modal"
                                            data-bs-target="#editEntryModal"
                                            aria-label="Edit entry for @entry.NetId"
                                            data-row-id="@entry.RowIdentifier"
                                            data-netid="@entry.NetId"
                                            data-checkin-date="@entry.CheckinTimestamp.ToString("yyyy-MM-dd")"
                                            data-checkin-time="@entry.CheckinTimestamp.ToString("HH:mm")"
                                            data-checkout-date="@(entry.CheckoutTimestamp?.ToString("yyyy-MM-dd") ?? "")"
                                            data-checkout-time="@(entry.CheckoutTimestamp?.ToString("HH:mm") ?? "")"
                                            data-department-id="@(entry.DepartmentId?.ToString() ?? "")"
                                            data-category-id="@(entry.ShiftCategoryId?.ToString() ?? "")">
                                        <i class="fas fa-pencil-alt"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
else
{
    <div class="alert alert-info">
        <i class="fas fa-info-circle"></i> No timesheet entries found for the selected filters.
    </div>
}

<!-- Edit Entry Modal -->
<div class="modal fade" id="editEntryModal" tabindex="-1" aria-labelledby="editEntryModalLabel" aria-modal="true" role="dialog">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="editEntryModalLabel">
                    <i class="fas fa-pencil-alt"></i> Edit Timesheet Entry
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" asp-page-handler="Edit">
                <div class="modal-body">
                    <p class="text-muted small mb-3">NetID: <code id="editNetIdDisplay"></code></p>

                    <!-- Hidden: row identifier + filter state preservation -->
                    <input type="hidden" name="EditRowId" id="editRowId" />
                    <input type="hidden" name="EditNetId" id="editNetId" />
                    <input type="hidden" name="StartDate" value="@Model.StartDate.ToString("yyyy-MM-dd")" />
                    <input type="hidden" name="EndDate" value="@Model.EndDate.ToString("yyyy-MM-dd")" />
                    <input type="hidden" name="FilterNetId" value="@Model.FilterNetId" />
                    <input type="hidden" name="FilterDepartmentId" value="@Model.FilterDepartmentId" />
                    <input type="hidden" name="FilterCategoryId" value="@Model.FilterCategoryId" />

                    <fieldset>
                        <legend class="visually-hidden">Edit timesheet entry</legend>

                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label for="editCheckinDate" class="form-label">Check-In Date <span aria-hidden="true" class="text-danger">*</span></label>
                                <input type="date" id="editCheckinDate" name="EditCheckinDate" class="form-control" required aria-required="true" />
                            </div>
                            <div class="col-md-6">
                                <label for="editCheckinTime" class="form-label">Check-In Time <span aria-hidden="true" class="text-danger">*</span></label>
                                <input type="time" id="editCheckinTime" name="EditCheckinTime" class="form-control" required aria-required="true" />
                            </div>
                        </div>

                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label for="editCheckoutDate" class="form-label">Check-Out Date</label>
                                <input type="date" id="editCheckoutDate" name="EditCheckoutDate" class="form-control" />
                                <div class="form-text">Leave blank to keep entry as active (checked in).</div>
                            </div>
                            <div class="col-md-6">
                                <label for="editCheckoutTime" class="form-label">Check-Out Time</label>
                                <input type="time" id="editCheckoutTime" name="EditCheckoutTime" class="form-control" />
                            </div>
                        </div>

                        <div class="row g-3">
                            @if (Model.Departments.Any())
                            {
                                <div class="col-md-6">
                                    <label for="editDepartmentId" class="form-label">Location</label>
                                    <select id="editDepartmentId" name="EditDepartmentId" class="form-select">
                                        <option value="">— None —</option>
                                        @foreach (var dept in Model.Departments)
                                        {
                                            <option value="@dept.DeptId">@dept.Name</option>
                                        }
                                    </select>
                                </div>
                            }
                            @if (Model.ShiftCategories.Any())
                            {
                                <div class="col-md-6">
                                    <label for="editCategoryId" class="form-label">Shift Category</label>
                                    <select id="editCategoryId" name="EditShiftCategoryId" class="form-select">
                                        <option value="">— None —</option>
                                        @foreach (var cat in Model.ShiftCategories)
                                        {
                                            <option value="@cat.Id">@cat.Name</option>
                                        }
                                    </select>
                                </div>
                            }
                        </div>
                    </fieldset>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save"></i> Save Changes
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.edit-entry-btn').forEach(function (btn) {
            btn.addEventListener('click', function () {
                var netid = btn.dataset.netid;
                document.getElementById('editRowId').value = btn.dataset.rowId;
                document.getElementById('editNetId').value = netid;
                document.getElementById('editNetIdDisplay').textContent = netid;
                document.getElementById('editCheckinDate').value = btn.dataset.checkinDate;
                document.getElementById('editCheckinTime').value = btn.dataset.checkinTime;
                document.getElementById('editCheckoutDate').value = btn.dataset.checkoutDate;
                document.getElementById('editCheckoutTime').value = btn.dataset.checkoutTime;

                var deptSelect = document.getElementById('editDepartmentId');
                if (deptSelect) deptSelect.value = btn.dataset.departmentId || '';

                var catSelect = document.getElementById('editCategoryId');
                if (catSelect) catSelect.value = btn.dataset.categoryId || '';
            });
        });
    </script>
}
