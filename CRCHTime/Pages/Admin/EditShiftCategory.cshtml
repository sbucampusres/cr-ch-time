@page "{id:int}"
@model CRCHTime.Pages.Admin.EditShiftCategoryModel
@{
    ViewData["Title"] = "Edit Shift Category";
}

<div class="row">
    <div class="col-12">
        <h1><i class="fas fa-edit icon-primary"></i> EDIT SHIFT CATEGORY</h1>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-body">
                <form method="post">
                    <fieldset>
                        <legend class="visually-hidden">Edit Shift Category</legend>

                        <input type="hidden" asp-for="Category.Id" />

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <div class="mb-3">
                            <label asp-for="Category.Name" class="form-label">Category Name <span aria-hidden="true" class="text-danger">*</span></label>
                            <input asp-for="Category.Name" class="form-control" required
                                   aria-required="true" />
                            <span asp-validation-for="Category.Name" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Category.Description" class="form-label">Description</label>
                            <textarea asp-for="Category.Description" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="Category.Description" class="text-danger small"></span>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save"></i> Save Changes
                            </button>
                            <a asp-page="/Admin/ManageShiftCategories" class="btn btn-outline-secondary">
                                Cancel
                            </a>
                        </div>
                    </fieldset>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
