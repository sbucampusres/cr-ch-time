@page "{id:int}"
@model CRCHTime.Pages.Admin.EditDepartmentModel
@{
    ViewData["Title"] = "Edit Department";
}

<div class="row">
    <div class="col-12">
        <h1><i class="fas fa-edit icon-primary"></i> EDIT DEPARTMENT</h1>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-body">
                <form method="post">
                    <fieldset>
                        <legend class="visually-hidden">Edit Department</legend>

                        <input type="hidden" asp-for="Department.DeptId" />

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <div class="mb-3">
                            <label asp-for="Department.Name" class="form-label">Department Name <span aria-hidden="true" class="text-danger">*</span></label>
                            <input asp-for="Department.Name" class="form-control" required
                                   maxlength="40" aria-required="true" />
                            <span asp-validation-for="Department.Name" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <div class="form-check">
                                <input asp-for="Department.Inactive" class="form-check-input" type="checkbox" />
                                <label asp-for="Department.Inactive" class="form-check-label">Inactive</label>
                            </div>
                            <div class="form-text">Inactive departments are hidden from staff check-in but their history is preserved.</div>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save"></i> Save Changes
                            </button>
                            <a asp-page="/Admin/ManageDepartments" class="btn btn-outline-secondary">
                                Cancel
                            </a>
                        </div>
                    </fieldset>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
