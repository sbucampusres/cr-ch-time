@page
@model CRCHTime.Pages.Admin.ManageShiftCategoriesModel
@{
    ViewData["Title"] = "Shift Categories";
}

<div class="row align-items-center mb-3">
    <div class="col">
        <h1><i class="fas fa-tags icon-primary"></i> SHIFT CATEGORIES</h1>
        <p class="text-muted">Application: <strong>@Model.CurrentApplication</strong></p>
    </div>
    <div class="col-auto">
        <a asp-page="/Admin/AddShiftCategory" class="btn btn-primary">
            <i class="fas fa-plus"></i> Add Category
        </a>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.StatusMessage))
{
    <div class="alert @(Model.IsSuccess ? "alert-success" : "alert-danger") alert-dismissible fade show"
         role="@(Model.IsSuccess ? "status" : "alert")" aria-live="polite">
        <i class="fas @(Model.IsSuccess ? "fa-check-circle" : "fa-exclamation-circle")"></i>
        @Model.StatusMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (Model.Categories.Any())
{
    <div class="card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <caption class="visually-hidden">Shift categories for @Model.CurrentApplication</caption>
                    <thead>
                        <tr>
                            <th scope="col">Name</th>
                            <th scope="col">Description</th>
                            <th scope="col">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var cat in Model.Categories)
                        {
                            <tr>
                                <td><strong>@cat.Name</strong></td>
                                <td><span class="text-muted">@(cat.Description ?? "—")</span></td>
                                <td>
                                    <a asp-page="/Admin/EditShiftCategory"
                                       asp-route-id="@cat.Id"
                                       class="btn btn-sm btn-outline-primary me-1">
                                        <i class="fas fa-edit"></i> Edit
                                    </a>
                                    <form method="post" asp-page-handler="Delete" asp-route-id="@cat.Id"
                                          class="d-inline"
                                          onsubmit="return confirm('Remove shift category \'@cat.Name\'?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            <i class="fas fa-trash"></i> Remove
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
else
{
    <div class="alert alert-info">
        <i class="fas fa-info-circle"></i> No shift categories defined yet.
        <a asp-page="/Admin/AddShiftCategory" class="alert-link">Add the first one.</a>
    </div>
}
