@page
@model CRCHTime.Pages.Staff.CheckInModel
@{
    ViewData["Title"] = "Staff Check-In";
}

<div class="row">
    <div class="col-12">
        <h1><i class="fas fa-sign-in-alt icon-primary"></i> STAFF CHECK-IN</h1>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.StatusMessage))
{
    <div class="alert @(Model.IsSuccess ? "alert-success" : "alert-danger") alert-dismissible fade show" role="@(Model.IsSuccess ? "status" : "alert")" aria-live="@(Model.IsSuccess ? "polite" : "assertive")">
        <i class="fas @(Model.IsSuccess ? "fa-check-circle" : "fa-exclamation-circle")"></i>
        @Model.StatusMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header">
                <h5><i class="fas fa-user-clock"></i> Check-In Status</h5>
            </div>
            <div class="card-body text-center">
                <p class="h4 mb-3">Welcome, <strong>@Model.DisplayName</strong></p>
                <p class="text-muted mb-3">NetID: @Model.NetId</p>

                <div class="mb-4">
                    <p class="h2 mb-0" id="currentTime" aria-live="polite">@DateTime.Now.ToString("h:mm:ss tt")</p>
                    <p class="text-muted">@DateTime.Now.ToString("dddd, MMMM d, yyyy")</p>
                </div>
                    <form method="post">
                        @if (Model.Departments.Any())
                        {
                            <div class="mb-4">
                                <label asp-for="DepartmentId" class="form-label">
                                    Location <span aria-hidden="true" class="text-danger">*</span>
                                </label>
                                <select asp-for="DepartmentId" class="form-select form-select-lg"
                                        asp-items="@(new SelectList(Model.Departments, "DeptId", "Name"))"
                                        required aria-required="true">
                                    <option value="">-- Select Location --</option>
                                </select>
                                <span asp-validation-for="DepartmentId" class="text-danger small"></span>
                            </div>
                        }
                        @if (Model.ShiftCategories.Any())
                        {
                            <div class="mb-1">
                                <label asp-for="ShiftCategoryId" class="form-label">
                                    Shift Category <span aria-hidden="true" class="text-danger">*</span>
                                </label>
                                <select id="ShiftCategoryId" name="ShiftCategoryId" class="form-select form-select-lg"
                                        required aria-required="true"
                                        aria-describedby="shiftCategoryDesc">
                                    <option value="">-- Select Shift Category --</option>
                                    @foreach (var cat in Model.ShiftCategories)
                                    {
                                        <option value="@cat.Id"
                                                data-description="@(cat.Description ?? "")"
                                                selected="@(Model.ShiftCategoryId == cat.Id ? "selected" : null)">
                                            @cat.Name
                                        </option>
                                    }
                                </select>
                                <span asp-validation-for="ShiftCategoryId" class="text-danger small"></span>
                            </div>
                            <div id="shiftCategoryDesc"
                                 class="text-muted small text-start mb-4 ps-1"
                                 aria-live="polite"
                                 style="min-height: 1.4em;"></div>
                        }
                        <div class="d-grid">
                            <button type="submit" class="btn btn-success btn-lg">
                                <i class="fas fa-sign-in-alt"></i> Check In Now
                            </button>
                        </div>
                    </form>
            </div>
        </div>

        @if (Model.ShiftCategories.Any(c => !string.IsNullOrWhiteSpace(c.Description)))
        {
            <details class="mt-3">
                <summary class="text-muted small" style="cursor: pointer; user-select: none;">
                    <i class="fas fa-info-circle"></i> What do these categories mean?
                </summary>
                <div class="card card-body mt-2 py-2 text-start">
                    <dl class="mb-0">
                        @foreach (var cat in Model.ShiftCategories.Where(c => !string.IsNullOrWhiteSpace(c.Description)))
                        {
                            <dt class="small fw-semibold">@cat.Name</dt>
                            <dd class="small text-muted mb-2">@cat.Description</dd>
                        }
                    </dl>
                </div>
            </details>
        }
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Update time display every second
        function updateTime() {
            const now = new Date();
            const timeStr = now.toLocaleTimeString('en-US', {
                hour: 'numeric',
                minute: '2-digit',
                second: '2-digit',
                hour12: true
            });
            document.getElementById('currentTime').textContent = timeStr;
        }
        setInterval(updateTime, 1000);

        // Inline shift category description (Option A)
        const categorySelect = document.getElementById('ShiftCategoryId');
        const categoryDesc = document.getElementById('shiftCategoryDesc');
        if (categorySelect && categoryDesc) {
            function updateCategoryDesc() {
                const selected = categorySelect.options[categorySelect.selectedIndex];
                categoryDesc.textContent = selected?.dataset.description || '';
            }
            categorySelect.addEventListener('change', updateCategoryDesc);
            updateCategoryDesc(); // show on page load if pre-selected
        }
    </script>
}
